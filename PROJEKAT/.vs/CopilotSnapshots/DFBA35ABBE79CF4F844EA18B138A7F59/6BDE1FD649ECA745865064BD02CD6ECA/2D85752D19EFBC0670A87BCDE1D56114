.homepage-wrapper {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-button {
  border: none;
  border-radius: 8px;
  padding: 12px 20px;
  font-size: 16px;
  font-weight: 600;
  cursor: pointer;
  background-color: #1f6feb;
  color: #ffffff;
}

.login-button:hover {
  background-color: #1557b5;
}
