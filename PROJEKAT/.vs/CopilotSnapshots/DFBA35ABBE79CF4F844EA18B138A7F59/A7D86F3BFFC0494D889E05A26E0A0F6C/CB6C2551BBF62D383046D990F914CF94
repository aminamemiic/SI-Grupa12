<div class="homepage-wrapper">
  <div class="actions">
    <button type="button" class="login-button" (click)="loginWithKeycloak()" [disabled]="isLoading">
      Log In
    </button>

    <button type="button" class="logout-button" (click)="logoutFromBackend()" [disabled]="isLoading">
      Logout
    </button>
  </div>

  @if (isLoading) {
    <p class="status-text">Login u toku...</p>
  }

  @if (errorMessage) {
    <p class="error-text">{{ errorMessage }}</p>
  }

  @if (infoMessage) {
    <p class="info-text">{{ infoMessage }}</p>
  }
</div>
